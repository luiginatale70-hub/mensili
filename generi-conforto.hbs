{{! views/mensile/generi-conforto.hbs }}
<div class="mensile-container">

  <nav class="mensile-breadcrumb">
    <a href="/mensile"><i class="fas fa-home"></i> MENSILE</a>
    <span class="sep">›</span>
    <span>Generi di Conforto</span>
  </nav>

  <div class="mensile-header">
    <div class="mensile-header-icon"><i class="fas fa-utensils"></i></div>
    <div>
      <h1>Generi di Conforto</h1>
      <p class="mensile-subtitle">Compilare i dati per generare lettera + allegato PDF</p>
    </div>
  </div>

  <form id="formGeneriConforto" class="mensile-form">

    <!-- DATI GENERALI -->
    <div class="mensile-card">
      <div class="mensile-card-title"><i class="fas fa-calendar-alt"></i> Dati Generali</div>
      <div class="mensile-grid-4">
        <div class="campo-gruppo">
          <label>Mese di riferimento</label>
          <select name="meseIdx" id="meseIdx" onchange="aggiornaMese()">
            <option value="0">GENNAIO</option><option value="1">FEBBRAIO</option>
            <option value="2">MARZO</option><option value="3">APRILE</option>
            <option value="4">MAGGIO</option><option value="5">GIUGNO</option>
            <option value="6">LUGLIO</option><option value="7">AGOSTO</option>
            <option value="8">SETTEMBRE</option><option value="9">OTTOBRE</option>
            <option value="10">NOVEMBRE</option><option value="11">DICEMBRE</option>
          </select>
        </div>
        <div class="campo-gruppo">
          <label>Anno</label>
          <input type="number" name="anno" id="anno" value="{{anno}}" min="2020" max="2099" onchange="aggiornaMese()">
        </div>
        <div class="campo-gruppo">
          <label>Data lettera</label>
          <input type="text" name="dataLettera" id="dataLettera">
        </div>
        <div class="campo-gruppo">
          <label>Giorni nel mese</label>
          <div class="info-badge" id="giorniMeseBadge">— gg</div>
        </div>
      </div>

      <!-- CAPO NUCLEO ASSENTE -->
      <div class="campo-gruppo" style="margin-top:12px">
        <label class="label-checkbox">
          <input type="checkbox" id="chkAssente" onchange="toggleAssente()">
          <span>Capo Nucleo assente — firma per delega</span>
        </label>
      </div>
      <div id="bloccoAssente" style="display:none; margin-top:12px; max-width:500px">
        <label>Sostituto (Piloti + EFV)</label>
        <select id="sostituto" class="select-grande">
          <option value="">— seleziona sostituto —</option>
        </select>
        <div id="anteprima-firma" class="anteprima-firma" style="display:none"></div>
      </div>
    </div>

    <!-- PILOTI -->
    <div class="mensile-card">
      <div class="mensile-card-title">
        <i class="fas fa-plane"></i> Piloti
        <button type="button" class="btn-aggiungi" id="btnAggiungiPilota">
          <i class="fas fa-plus"></i> Aggiungi Pilota
        </button>
      </div>
      <div class="table-responsive">
        <table class="mensile-table">
          <thead>
            <tr>
              <th class="col-num">#</th>
              <th class="col-grado">Grado / Categoria</th>
              <th class="col-cognome">Cognome</th>
              <th class="col-nome">Nome</th>
              <th class="col-gg">GG Generi<br>Conforto</th>
              <th class="col-imp">Importo<br>Generi (€)</th>
              <th class="col-gg">GG<br>Colazione</th>
              <th class="col-imp">Importo<br>Colazione (€)</th>
              <th class="col-tot">Totale</th>
              <th class="col-del"></th>
            </tr>
          </thead>
          <tbody id="bodyPiloti"></tbody>
          <tfoot>
            <tr class="riga-totale">
              <td colspan="8" class="label-totale">Totale Piloti:</td>
              <td id="totalePiloti" class="tot-cell">€ 0.00</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- EQUIPAGGI FISSI DI VOLO -->
    <div class="mensile-card">
      <div class="mensile-card-title">
        <i class="fas fa-users"></i> Equipaggi Fissi di Volo
        <button type="button" class="btn-aggiungi" id="btnAggiungiEFV">
          <i class="fas fa-plus"></i> Aggiungi EFV
        </button>
      </div>
      <div class="table-responsive">
        <table class="mensile-table">
          <thead>
            <tr>
              <th class="col-num">#</th>
              <th class="col-grado">Grado / Categoria</th>
              <th class="col-cognome">Cognome</th>
              <th class="col-nome">Nome</th>
              <th class="col-ggwide">GG Generi di Conforto</th>
              <th class="col-tot">Totale (€/gg)</th>
              <th class="col-del"></th>
            </tr>
          </thead>
          <tbody id="bodyEquipaggi"></tbody>
          <tfoot>
            <tr class="riga-totale">
              <td colspan="5" class="label-totale">Totale Equipaggi:</td>
              <td id="totaleEquipaggi" class="tot-cell">€ 0.00</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- RIEPILOGO -->
    <div class="mensile-card mensile-card-genera">
      <div class="riepilogo-finale">
        <div class="riepilogo-row"><span>Totale Piloti:</span><span id="riepilogoPiloti">€ 0.00</span></div>
        <div class="riepilogo-row"><span>Totale Equipaggi:</span><span id="riepilogoEquipaggi">€ 0.00</span></div>
        <div class="riepilogo-row riepilogo-totale"><span>TOTALE GENERALE:</span><span id="riepilogoTotale">€ 0.00</span></div>
        <div class="tariffe-info" id="tariffeInfo"></div>
      </div>
      <div class="genera-actions">
        <button type="button" class="btn-genera" id="btnGenera">
          <i class="fas fa-file-pdf"></i> Genera PDF e Archivia
        </button>
        <button type="button" class="btn-reset" onclick="resetForm()">
          <i class="fas fa-undo"></i> Reset
        </button>
      </div>
    </div>
  </form>

  <div id="risultatoBox" class="mensile-risultato" style="display:none">
    <div class="risultato-ok"><i class="fas fa-check-circle"></i><strong>PDF generati e archiviati!</strong></div>
    <div id="listaFiles" class="lista-files"></div>
  </div>
  <div id="erroreBox" class="mensile-errore" style="display:none">
    <i class="fas fa-exclamation-triangle"></i><span id="erroreMsg"></span>
  </div>

  <!-- MODALI -->
  <div id="modalePiloti" class="modale" style="display:none">
    <div class="modale-box">
      <div class="modale-titolo">
        <i class="fas fa-plane"></i> Seleziona Pilota
        <button type="button" class="modale-chiudi" onclick="chiudiModale('modalePiloti')">&#x2715;</button>
      </div>
      <div id="listaPiloti" class="modale-lista"></div>
    </div>
  </div>
  <div id="modaleEFV" class="modale" style="display:none">
    <div class="modale-box">
      <div class="modale-titolo">
        <i class="fas fa-users"></i> Seleziona Membro EFV
        <button type="button" class="modale-chiudi" onclick="chiudiModale('modaleEFV')">&#x2715;</button>
      </div>
      <div id="listaEFV" class="modale-lista"></div>
    </div>
  </div>

</div>
<script>
var CFG = { personale:{}, tariffe:{} };
var giorniMese = 31, idxP = 0, idxE = 0;
function $(s){ return document.getElementById(s); }
function q(s){ return document.querySelector(s); }
function sv(sel,v){ var e=q(sel); if(e) e.value=v; }
function esc(s){ return (s||'').replace(/"/g,'&quot;'); }

document.addEventListener('DOMContentLoaded', async function(){
  var oggi = new Date();
  $('meseIdx').value = oggi.getMonth();
  $('anno').value = oggi.getFullYear();
  var d = String(oggi.getDate()).padStart(2,'0');
  var m = String(oggi.getMonth()+1).padStart(2,'0');
  $('dataLettera').value = d+'/'+m+'/'+oggi.getFullYear();
  await caricaConfig();
  await aggiornaMese();
  $('btnAggiungiPilota').onclick = function(){ apriModale('modalePiloti'); };
  $('btnAggiungiEFV').onclick    = function(){ apriModale('modaleEFV'); };
  $('btnGenera').onclick = generaPDF;
  document.querySelectorAll('.modale').forEach(function(m){
    m.addEventListener('click', function(e){ if(e.target===m) m.style.display='none'; });
  });
  $('sostituto').addEventListener('change', aggiornaAnteprima);
});

async function caricaConfig(){
  try{ CFG = await (await fetch('/mensile/api/config')).json(); }
  catch(e){ CFG = { personale:{capoNucleo:[],piloti:[],efv:[]}, tariffe:{} }; }

  // Capo Nucleo automatico — primo del file personale.json
  CFG.capoNucleoAttivo = (CFG.personale.capoNucleo||[])[0] || '';

  // Popola sostituto con Piloti + EFV
  var selSos = $('sostituto');
  (CFG.personale.piloti||[]).forEach(function(p){
    var o = document.createElement('option');
    o.value = p.grado+'|'+p.nome+'|'+p.cognome;
    o.textContent = p.grado+' '+p.nome+' '+p.cognome;
    selSos.appendChild(o);
  });
  (CFG.personale.efv||[]).forEach(function(e){
    var o = document.createElement('option');
    o.value = e.grado+'|'+e.nome+'|'+e.cognome;
    o.textContent = e.grado+' '+e.nome+' '+e.cognome;
    selSos.appendChild(o);
  });

  // Popola modali
  var lp = $('listaPiloti'); lp.innerHTML = '';
  (CFG.personale.piloti||[]).forEach(function(p){
    var btn = mkBtn(p.grado, p.cognome+' '+p.nome);
    btn.onclick = function(){ aggiungiPilota(p); chiudiModale('modalePiloti'); };
    lp.appendChild(btn);
  });
  var le = $('listaEFV'); le.innerHTML = '';
  (CFG.personale.efv||[]).forEach(function(e){
    var btn = mkBtn(e.grado, e.cognome+' '+e.nome);
    btn.onclick = function(){ aggiungiEFV(e); chiudiModale('modaleEFV'); };
    le.appendChild(btn);
  });

  var t = CFG.tariffe||{};
  $('tariffeInfo').innerHTML = '<i class="fas fa-info-circle"></i> Generi: <strong>€ '
    +(t.generiConforto&&t.generiConforto.importoGiornaliero||2.41)
    +'/gg</strong> &nbsp;|&nbsp; Colazione: <strong>€ '
    +(t.colazioneObbligatoria&&t.colazioneObbligatoria.importoGiornaliero||1.85)+'/gg</strong>';
}

function mkBtn(grado, nome){
  var btn = document.createElement('button');
  btn.type = 'button';
  btn.className = 'modale-item';
  btn.innerHTML = '<span class="item-grado">'+grado+'</span><span class="item-nome">'+nome+'</span>';
  return btn;
}

async function aggiornaMese(){
  var mi = $('meseIdx').value, an = $('anno').value;
  try{
    var j = await (await fetch('/mensile/api/giorni?mese='+mi+'&anno='+an)).json();
    giorniMese = j.giorni;
  } catch(e){
    giorniMese = [31,28,31,30,31,30,31,31,30,31,30,31][parseInt(mi)];
  }
  $('giorniMeseBadge').textContent = giorniMese+' gg';
  document.querySelectorAll('.inp-gg-generi').forEach(function(inp){
    inp.max = giorniMese;
    if(parseInt(inp.value) > giorniMese) inp.value = giorniMese;
  });
  aggiornaTotali();
}

function tar(tipo){
  var t = CFG.tariffe||{};
  if(tipo==='generi') return parseFloat(t.generiConforto&&t.generiConforto.importoGiornaliero||2.41);
  return parseFloat(t.colazioneObbligatoria&&t.colazioneObbligatoria.importoGiornaliero||1.85);
}

function aggiungiPilota(p){
  var idx = idxP++, tbody = $('bodyPiloti');
  var tr = document.createElement('tr');
  tr.dataset.idx = idx;
  tr.innerHTML =
    '<td class="num-cell">'+(tbody.children.length+1)+'</td>'
    +'<td><input type="text" name="piloti['+idx+'][grado]" value="'+esc(p&&p.grado)+'" class="inp-testo inp-grado"></td>'
    +'<td><input type="text" name="piloti['+idx+'][cognome]" value="'+esc(p&&p.cognome)+'" class="inp-testo inp-upper"></td>'
    +'<td><input type="text" name="piloti['+idx+'][nome]" value="'+esc(p&&p.nome)+'" class="inp-testo"></td>'
    +'<td><input type="number" name="piloti['+idx+'][giorniGeneri]" class="inp-num inp-gg-generi" min="0" max="'+giorniMese+'" value="'+giorniMese+'" oninput="calcP('+idx+')"></td>'
    +'<td><input type="text" name="piloti['+idx+'][importoGeneri]" class="inp-num inp-calc" readonly></td>'
    +'<td><input type="number" name="piloti['+idx+'][giorniColazione]" class="inp-num" min="0" max="999" value="0" oninput="calcP('+idx+')"></td>'
    +'<td><input type="text" name="piloti['+idx+'][importoColazione]" class="inp-num inp-calc" readonly></td>'
    +'<td><input type="text" name="piloti['+idx+'][totale]" class="inp-num inp-calc inp-totale-riga" readonly></td>'
    +'<td><button type="button" class="btn-rimuovi" onclick="rimuovi(this,\'Piloti\')"><i class="fas fa-trash"></i></button></td>';
  tbody.appendChild(tr);
  calcP(idx);
}

function aggiungiEFV(e){
  var idx = idxE++, tbody = $('bodyEquipaggi');
  var tr = document.createElement('tr');
  tr.dataset.idx = idx;
  tr.innerHTML =
    '<td class="num-cell">'+(tbody.children.length+1)+'</td>'
    +'<td><input type="text" name="equipaggi['+idx+'][grado]" value="'+esc(e&&e.grado)+'" class="inp-testo inp-grado"></td>'
    +'<td><input type="text" name="equipaggi['+idx+'][cognome]" value="'+esc(e&&e.cognome)+'" class="inp-testo inp-upper"></td>'
    +'<td><input type="text" name="equipaggi['+idx+'][nome]" value="'+esc(e&&e.nome)+'" class="inp-testo"></td>'
    +'<td><input type="number" name="equipaggi['+idx+'][giorniGeneri]" class="inp-num inp-gg-generi" min="0" max="'+giorniMese+'" value="'+giorniMese+'" oninput="calcE('+idx+')"></td>'
    +'<td><input type="text" name="equipaggi['+idx+'][importoGeneri]" class="inp-num inp-calc" readonly></td>'
    +'<td><button type="button" class="btn-rimuovi" onclick="rimuovi(this,\'Equipaggi\')"><i class="fas fa-trash"></i></button></td>';
  tbody.appendChild(tr);
  calcE(idx);
}

function calcP(idx){
  var ggG = parseFloat((q('[name="piloti['+idx+'][giorniGeneri]"]')||{}).value)||0;
  var ggC = parseFloat((q('[name="piloti['+idx+'][giorniColazione]"]')||{}).value)||0;
  var iG = ggG*tar('generi'), iC = ggC*tar('colazione'), tot = iG+iC;
  sv('[name="piloti['+idx+'][importoGeneri]"]',    iG  ? iG.toFixed(2)  : '');
  sv('[name="piloti['+idx+'][importoColazione]"]', iC  ? iC.toFixed(2)  : '');
  sv('[name="piloti['+idx+'][totale]"]',           tot ? tot.toFixed(2) : '');
  aggiornaTotali();
}

function calcE(idx){
  var gg = parseFloat((q('[name="equipaggi['+idx+'][giorniGeneri]"]')||{}).value)||0;
  var imp = gg * tar('generi');
  sv('[name="equipaggi['+idx+'][importoGeneri]"]', imp ? imp.toFixed(2) : '');
  aggiornaTotali();
}

function aggiornaTotali(){
  var tP=0; document.querySelectorAll('[name$="[totale]"]').forEach(function(e){ tP+=parseFloat(e.value)||0; });
  var tE=0; document.querySelectorAll('#bodyEquipaggi [name$="[importoGeneri]"]').forEach(function(e){ tE+=parseFloat(e.value)||0; });
  var tG = tP+tE;
  $('totalePiloti').textContent       = '€ '+tP.toFixed(2);
  $('totaleEquipaggi').textContent    = '€ '+tE.toFixed(2);
  $('riepilogoPiloti').textContent    = '€ '+tP.toFixed(2);
  $('riepilogoEquipaggi').textContent = '€ '+tE.toFixed(2);
  $('riepilogoTotale').textContent    = '€ '+tG.toFixed(2);
}

function rimuovi(btn, s){
  btn.closest('tr').remove();
  document.querySelectorAll('#body'+s+' tr').forEach(function(tr,i){
    tr.querySelector('.num-cell').textContent = i+1;
  });
  aggiornaTotali();
}

function apriModale(id){ $(id).style.display='flex'; }
function chiudiModale(id){ $(id).style.display='none'; }

function serializzaForm(){
  var dati = {
    meseIdx:     $('meseIdx').value,
    anno:        $('anno').value,
    dataLettera: $('dataLettera').value,
    capoNucleo:  CFG.capoNucleoAttivo,
    piloti:      [],
    equipaggi:   []
  };
  document.querySelectorAll('#bodyPiloti tr').forEach(function(tr){
    var i = tr.dataset.idx;
    var cog = (tr.querySelector('[name="piloti['+i+'][cognome]"]')||{}).value;
    if(!cog||!cog.trim()) return;
    dati.piloti.push({
      grado:           (tr.querySelector('[name="piloti['+i+'][grado]"]')          ||{}).value||'',
      cognome:         cog.trim(),
      nome:            (tr.querySelector('[name="piloti['+i+'][nome]"]')            ||{}).value||'',
      giorniGeneri:    (tr.querySelector('[name="piloti['+i+'][giorniGeneri]"]')    ||{}).value||0,
      importoGeneri:   (tr.querySelector('[name="piloti['+i+'][importoGeneri]"]')   ||{}).value||'0',
      giorniColazione: (tr.querySelector('[name="piloti['+i+'][giorniColazione]"]') ||{}).value||0,
      importoColazione:(tr.querySelector('[name="piloti['+i+'][importoColazione]"]')||{}).value||'',
      totale:          (tr.querySelector('[name="piloti['+i+'][totale]"]')          ||{}).value||'0',
    });
  });
  document.querySelectorAll('#bodyEquipaggi tr').forEach(function(tr){
    var i = tr.dataset.idx;
    var cog = (tr.querySelector('[name="equipaggi['+i+'][cognome]"]')||{}).value;
    if(!cog||!cog.trim()) return;
    dati.equipaggi.push({
      grado:        (tr.querySelector('[name="equipaggi['+i+'][grado]"]')        ||{}).value||'',
      cognome:      cog.trim(),
      nome:         (tr.querySelector('[name="equipaggi['+i+'][nome]"]')         ||{}).value||'',
      giorniGeneri: (tr.querySelector('[name="equipaggi['+i+'][giorniGeneri]"]') ||{}).value||0,
      importoGeneri:(tr.querySelector('[name="equipaggi['+i+'][importoGeneri]"]')||{}).value||'0',
    });
  });
  return dati;
}

async function generaPDF(){
  var dati = serializzaForm();

  var assente = $('chkAssente').checked;
  if(assente){
    var sos = $('sostituto').value;
    if(!sos){ mostraErr('Selezionare il sostituto.'); return; }
    var parts = sos.split('|');
    dati.firmaAssente = true;
    dati.sostituito   = dati.capoNucleo;
    dati.sostituto    = parts[0]+' '+parts[1]+' '+parts[2];
  } else {
    dati.firmaAssente = false;
  }

  if(!dati.piloti.length && !dati.equipaggi.length){ mostraErr('Inserire almeno un pilota o EFV.'); return; }

  var btn = $('btnGenera');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generazione...';
  $('risultatoBox').style.display = $('erroreBox').style.display = 'none';
  try{
    var j = await (await fetch('/mensile/generi-conforto/genera',{
      method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(dati)
    })).json();
    if(j.ok){
      $('listaFiles').innerHTML = j.files.map(function(f){
        return '<div class="file-item">'
          +'<i class="fas fa-file-pdf"></i>'
          +'<span class="file-nome">'+f.nome+'</span>'
          +'<div class="file-btns">'
          +'<a href="/mensile/view?path='+encodeURIComponent(f.path)+'" class="btn-view" target="_blank">'
          +'<i class="fas fa-eye"></i> Visualizza</a>'
          +'<a href="/mensile/download?path='+encodeURIComponent(f.path)+'" class="btn-download" download>'
          +'<i class="fas fa-download"></i> Scarica</a>'
          +'</div></div>';
      }).join('');
      $('risultatoBox').style.display = 'block';
      $('risultatoBox').scrollIntoView({behavior:'smooth'});
    } else {
      mostraErr(j.errore||'Errore sconosciuto.');
    }
  } catch(e){
    mostraErr('Errore: '+e.message);
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-file-pdf"></i> Genera PDF e Archivia';
  }
}

function mostraErr(msg){
  $('erroreMsg').textContent = msg;
  $('erroreBox').style.display = 'block';
  $('erroreBox').scrollIntoView({behavior:'smooth'});
}

function resetForm(){
  if(!confirm('Azzerare tutti i dati?')) return;
  $('bodyPiloti').innerHTML = $('bodyEquipaggi').innerHTML = '';
  idxP = idxE = 0;
  aggiornaTotali();
  $('risultatoBox').style.display = $('erroreBox').style.display = 'none';
}

function toggleAssente(){
  var chk = $('chkAssente').checked;
  $('bloccoAssente').style.display = chk ? 'block' : 'none';
  aggiornaAnteprima();
}

function aggiornaAnteprima(){
  var div = $('anteprima-firma');
  var chk = $('chkAssente').checked;
  if(!chk){ div.style.display='none'; return; }
  var capo   = CFG.capoNucleoAttivo || '';
  var selSos = $('sostituto');
  var sosVal = selSos.selectedIndex > 0 ? selSos.options[selSos.selectedIndex].text : '';
  if(!capo || !sosVal){ div.style.display='none'; return; }
  div.style.display = 'block';
  div.innerHTML = '<strong>Anteprima firma:</strong><br>'
    + 'P. IL CAPO NUCLEO<br>'
    + capo + ' t.a.<br>'
    + sosVal;
}
</script>
