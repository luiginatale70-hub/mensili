/**
 * pdfGenerator.js — v5
 * Fedele al documento Word originale analizzato al mm
 *
 * Misure estratte dal XML del .doc:
 *   Pagina: 210x297mm  Margini: T=10 B=20 L=17 R=17 mm
 *   Stemma OLE: 27.5 x 24.1 mm
 *   Separatore: dotDash (tratteggiato)
 *   T0 colonne: sx=84.2mm  mid=22.2mm  dx=67.8mm
 *   T1 colonne: oggetto=38.6+134.6mm  corpo=41+135mm
 */

const PDFDocument = require('pdfkit');
const path = require('path');
const fs   = require('fs');

// Stemma Repubblica Italiana (embedded base64)
const STEMMA_B64 = "";
const STEMMA_BUF = Buffer.from(STEMMA_B64, 'base64');

// ── mm → pt ───────────────────────────────────────────────────────────────────
const mm = v => v * 2.8346;

// ── Misure pagina ─────────────────────────────────────────────────────────────
const PG_W  = mm(210), PG_H  = mm(297);
const MAR_T = mm(10),  MAR_B = mm(20);
const MAR_L = mm(17),  MAR_R = mm(17);
const BODY_W = PG_W - MAR_L - MAR_R;  // 498.9 pt

// ── Colonne Tabella 0 (intestazione) ─────────────────────────────────────────
const T0_SX  = mm(84.2);   // sinistra: stemma + Ministero
const T0_MID = mm(22.2);   // centrale: "Alla"
const T0_DX  = mm(67.8);   // destra: Destinatario

// ── Colonne Tabella 1 (corpo lettera) ────────────────────────────────────────
const T1_OGG_L = mm(38.6);   // "OGGETTO:"
const T1_OGG_R = mm(134.6);  // testo oggetto
const T1_SPA   = mm(41.0);   // spazio protocolli
const T1_CORPO = mm(135.0);  // corpo testo

const F      = 'Helvetica';
const F_BOLD = 'Helvetica-Bold';
const F_BOBL = 'Helvetica-BoldOblique';

// ── Buffer helper ─────────────────────────────────────────────────────────────
function docToBuffer(doc) {
  return new Promise((resolve, reject) => {
    const chunks = [];
    doc.on('data', c => chunks.push(c));
    doc.on('end',  () => resolve(Buffer.concat(chunks)));
    doc.on('error', e => reject(e));
  });
}

// ── Linea tratteggiata (stile dotDash come originale) ─────────────────────────
function dashedLine(doc, x1, y, x2, lw = 0.5) {
  doc.save()
     .moveTo(x1, y).lineTo(x2, y)
     .lineWidth(lw).dash(3, { space: 3 }).stroke('#000')
     .undash().restore();
}

// ── Linea continua ────────────────────────────────────────────────────────────
function solidLine(doc, x1, y, x2, lw = 0.5) {
  doc.save().moveTo(x1, y).lineTo(x2, y).lineWidth(lw).stroke('#000').restore();
}

// ── Bordo rettangolo ──────────────────────────────────────────────────────────
function border(doc, x, y, w, h, lw = 0.4) {
  doc.save().rect(x, y, w, h).lineWidth(lw).stroke('#000').restore();
}

// =============================================================================
// LETTERA DI ACCOMPAGNAMENTO — fedele all'originale riga per riga
// =============================================================================
async function generaLettera(dati) {
  const doc = new PDFDocument({
    size: [PG_W, PG_H], margin: 0,
    info: { Title: `Generi di Conforto — ${dati.meseNome} ${dati.anno}` }
  });
  const buf = docToBuffer(doc);

  // ════════════════════════════════════════
  // BLOCCO SUPERIORE — Tabella 0
  // ════════════════════════════════════════
  let y = MAR_T;
  const xSX = MAR_L;
  const xMID = MAR_L + T0_SX;
  const xDX  = MAR_L + T0_SX + T0_MID;

  // ── STEMMA ───────────────────────────────────────────────────────────────
  const stemmaExt = path.join(__dirname, '..', 'public', 'images', 'stemma.png');
  const stemmaBuf = fs.existsSync(stemmaExt) ? stemmaExt : STEMMA_BUF;
  doc.image(stemmaBuf, xSX, y, { width: mm(27.5), height: mm(24.1) });

  // ── "65131 Pescara," in alto a destra ────────────────────────────────────
  // FIX 1: fontSize 12 su tutto
  doc.font(F).fontSize(12).fillColor('#000')
     .text('65131 Pescara,', xDX, y, { width: T0_DX });
  solidLine(doc, xDX, y + mm(6), xDX + T0_DX);

  // ── Ministero / Direzione / Pescara — centrato sotto stemma ─────────────
  const yMin = y + mm(26);
  doc.font(F).fontSize(12).fillColor('#000')
     .text('Ministero delle Infrastrutture e dei Trasporti', xSX, yMin, { width: T0_SX, align: 'center' });
  doc.text('Direzione Marittima', xSX, yMin + mm(6), { width: T0_SX, align: 'center' });
  doc.text('Pescara', xSX, yMin + mm(12), { width: T0_SX, align: 'center' });

  // FIX 3: "Alla DIREZIONE" parte da y (stessa riga di "65131 Pescara,")
  //         che è UNA RIGA PIÙ SU rispetto a yMin (dove inizia il Ministero)
  const yDest = y;   // <-- allineato con "65131 Pescara,", sopra il Ministero

  // FIX 2: due spazi tra "Alla" e "DIREZIONE MARITTIMA"
  doc.font(F).fontSize(12).fillColor('#000')
     .text('Alla', xMID, yDest, { width: T0_MID, align: 'right' });
  doc.font(F_BOLD).fontSize(12)
     .text('  DIREZIONE MARITTIMA', xDX, yDest, { width: T0_DX });
  doc.font(F).fontSize(12)
     .text('Segreteria Gestione Contabile del personale', xDX, yDest + mm(6), { width: T0_DX });
  doc.text('- P E S C A R A -', xDX, yDest + mm(13), { width: T0_DX });

  // ── Separatore tratteggiato solo col sx ──────────────────────────────────
  const ySep = yMin + mm(19);
  dashedLine(doc, xSX, ySep, xMID);

  // ── Nucleo / Mail / Titolario ────────────────────────────────────────────
  let yNucleo = ySep + mm(3);
  doc.font(F).fontSize(12).fillColor('#000')
     .text('Nucleo Addestramento Ala Fissa', xSX, yNucleo, { width: T0_SX, align: 'center' });
  yNucleo += mm(7);
  doc.text('Mail: naaf@mit.gov.it', xSX, yNucleo, { width: T0_SX });
  yNucleo += mm(7);
  doc.text("Posizione Titolario d'Archivio", xSX, yNucleo, { width: mm(55) });
  doc.text('All.:  _1_', xSX + mm(58), yNucleo, { width: mm(26) });

  // ════════════════════════════════════════
  // TABELLA 1 — OGGETTO + CORPO
  // ════════════════════════════════════════
  let yT1 = yNucleo + mm(10);

  // ── Riga OGGETTO ─────────────────────────────────────────────────────────
  doc.font(F_BOLD).fontSize(12).fillColor('#000')
     .text('OGGETTO:', xSX + mm(2), yT1, { width: T1_OGG_L - mm(2) });
  doc.font(F).fontSize(12)
     .text(`Generi di conforto. Personale N.A.A.F. \u2013 Mese ${dati.meseNome} ${dati.anno}.-`,
           xSX + T1_OGG_L, yT1, { width: T1_OGG_R, align: 'justify' });

  yT1 += mm(10);
  solidLine(doc, xSX, yT1, xSX + T1_OGG_L + T1_OGG_R);
  yT1 += mm(3);

  // ── Separatrice verticale corpo ───────────────────────────────────────────
  const xCorpoDX  = xSX + T1_SPA;
  const yCorpoTop = yT1;

  // ── Spazio protocolli sx ──────────────────────────────────────────────────
  doc.font(F).fontSize(10).fillColor('#666')
     .text('(Spazio riservato a protocolli, visti\ne decretazioni)',
           xSX + mm(2), yT1 + mm(2), { width: T1_SPA - mm(4) });

  // ── Corpo testo dx ────────────────────────────────────────────────────────
  // FIX 4: tutto il corpo parte da xCorpoDX (stessa colonna di "SMM")
  let yDx = yT1 + mm(3);
  const xCorpo = xCorpoDX;   // colonna fissa per tutto il corpo

  // Riferimenti — "Riferimenti:" e "SMM" alla stessa x
  doc.font(F).fontSize(12).fillColor('#000')
     .text('Riferimenti:', xCorpo, yDx, { width: T1_CORPO });
  yDx += mm(8);
  doc.text('SMM - LOG - 020 Edizione luglio 2019;',
           xCorpo, yDx, { width: T1_CORPO });
  yDx += mm(14);

  // Paragrafo 1 — rientro prima riga + mese sottolineato
  const p1a = `    Si trasmette, in allegato, l\u2019elenco del personale di questo Nucleo Addestramento riportante le spettanze dei generi di conforto, come previsto dalla pubblicazione in riferimento, per il mese di `;
  const p1b = `${dati.meseNome} ${dati.anno}.`;
  doc.font(F).fontSize(12).fillColor('#000')
     .text(p1a, xCorpo, yDx, { width: T1_CORPO, align: 'justify', continued: true })
     .text(p1b, { underline: true, continued: false });
  yDx += doc.heightOfString(p1a + p1b, { width: T1_CORPO }) + mm(4);

  // Paragrafo 2 — rientro prima riga
  const p2 = `    Per questioni logistiche, trattandosi di personale sovente in missione, si chiede la somministrazione in contanti anzich\u00e9 in natura.`;
  doc.font(F).fontSize(12).fillColor('#000')
     .text(p2, xCorpo, yDx, { width: T1_CORPO, align: 'justify' });
  yDx += doc.heightOfString(p2, { width: T1_CORPO }) + mm(16);

  // ── FIRMA ─────────────────────────────────────────────────────────────────
  doc.font(F_BOLD).fontSize(12).fillColor('#000')
     .text('IL CAPO NUCLEO', xCorpoDX, yDx, { width: T1_CORPO, align: 'center' });
  yDx += mm(7);
  doc.font(F_BOLD).fontSize(12)
     .text(dati.capoNucleo, xCorpoDX, yDx, { width: T1_CORPO, align: 'center' });
  yDx += mm(14);

  // ── Box firma digitale (image1.png dal doc originale = 54x18.8mm) ────────
  const bW = mm(54), bH = mm(18.8);
  const bX = xCorpoDX + (T1_CORPO - bW) / 2;
  border(doc, bX, yDx, bW, bH, 0.5);
  doc.font(F).fontSize(6).fillColor('#333')
     .text(
       'Documento informatico firmato\ndigitalmente ai sensi del testo unico D.P.R.\n28 dicembre 2000 n. 445 e D.Lgs. 7 marzo\n2005 n. 82 e norme collegate.',
       bX + mm(2), yDx + mm(2), { width: bW - mm(4), align: 'center' }
     );

  // Linea verticale corpo (da yCorpoTop a fine firma)
  const yCorpoBot = yDx + bH + mm(2);
  doc.save()
     .moveTo(xCorpoDX, yCorpoTop).lineTo(xCorpoDX, yCorpoBot)
     .lineWidth(0.5).stroke('#000').restore();

  doc.end();
  return buf;
}

// =============================================================================
// ALLEGATO — TABELLA ELENCO PERSONALE
// =============================================================================
async function generaAllegato(dati) {
  const doc = new PDFDocument({
    size: [PG_W, PG_H], margin: 0,
    info: { Title: `Allegato Generi di Conforto — ${dati.meseNome} ${dati.anno}` }
  });
  const buf = docToBuffer(doc);
  let y = MAR_T + mm(5);

  // Intestazione bold centrata
  doc.font(F_BOLD).fontSize(11).fillColor('#000');
  for (const t of ['MINISTERO DELLE INFRASTRUTTURE E DEI TRASPORTI',
                    'DIREZIONE MARITTIMA','NUCLEO ADDESTRAMENTO ALA FISSA','PESCARA']) {
    doc.text(t, MAR_L, y, { width: BODY_W, align: 'center' });
    y += mm(6);
  }
  y += mm(8);

  doc.font(F).fontSize(8.5);
  for (const t of [
    'ELENCO PERSONALE E RELATIVE GIORNATE PER CUI SPETTANO I GENERI DI CONFORTO E LA COLAZIONE',
    'OBBLIGATORIA  GIUSTA :',
    'S M M 20 - LOG -020   Edizione luglio 2019',
    'NORME PER IL SERVIZIO DI VETTOVAGLIAMENTO DEL PERSONALE DELLA MARINA MILITARE'
  ]) {
    doc.text(t, MAR_L, y, { width: BODY_W, align: 'center' });
    y += mm(5);
  }
  y += mm(8);

  doc.font(F_BOLD).fontSize(11)
     .text(`MESE DI ${dati.meseNome} ${dati.anno}`, MAR_L, y, { width: BODY_W, align: 'center' });
  y += mm(12);

  // ── PILOTI ────────────────────────────────────────────────────────────────
  doc.font(F_BOLD).fontSize(10)
     .text('PILOTI', MAR_L, y, { width: BODY_W, align: 'center', underline: true });
  y += mm(7);

  const cpR = [8,80,82,65,52,52,42,52,52];
  const cpS = cpR.reduce((a,b)=>a+b,0);
  const cp  = cpR.map(w => BODY_W * w / cpS);

  y = rHdr(doc, y, [
    {t:'GRADO/CATEG.',w:cp[0]+cp[1]},{t:'COGNOME',w:cp[2]},{t:'NOME',w:cp[3]},
    {t:'GIORNI GENERI DI\nCONFORTO',w:cp[4]},
    {t:'Importo\ngiornaliero € 2,41',w:cp[5]},
    {t:'GIORNI\nCOLAZIONE',w:cp[6]},
    {t:'Importo\ngiornaliero',w:cp[7]},
    {t:'TOTALE',w:cp[8]}
  ], mm(10));

  let totP = 0;
  (dati.piloti||[]).forEach((p,i) => {
    const tot = parseFloat(p.totale)||0; totP += tot;
    const hc = p.giorniColazione && parseInt(p.giorniColazione)>0;
    y = rDat(doc, y, [
      {t:String(i+1),w:cp[0],a:'center'},{t:p.grado,w:cp[1]},
      {t:p.cognome,w:cp[2]},{t:p.nome,w:cp[3]},
      {t:String(p.giorniGeneri||0),w:cp[4],a:'center'},
      {t:`\u20ac ${parseFloat(p.importoGeneri||0).toFixed(2)}`,w:cp[5],a:'right'},
      {t:hc?String(p.giorniColazione):'',w:cp[6],a:'center'},
      {t:hc?`\u20ac ${parseFloat(p.importoColazione).toFixed(2)}`:'\u20ac 0,00',w:cp[7],a:'right'},
      {t:`\u20ac ${tot.toFixed(2)}`,w:cp[8],a:'right',b:true},
    ], mm(7));
  });
  y += mm(1);
  doc.font(F_BOBL).fontSize(10)
     .text(`\u20ac ${totP.toFixed(2)}`, MAR_L, y, { width: BODY_W, align: 'right' });
  y += mm(10);

  // ── EQUIPAGGI FISSI DI VOLO ───────────────────────────────────────────────
  doc.font(F_BOLD).fontSize(10)
     .text('ECQUIPAGGI FISSI DI VOLO', MAR_L, y, { width: BODY_W, align: 'center', underline: true });
  y += mm(7);

  const ceR = [8,80,82,65,100,80];
  const ceS = ceR.reduce((a,b)=>a+b,0);
  const ce  = ceR.map(w => BODY_W * w / ceS);

  y = rHdr(doc, y, [
    {t:'GRADO/CATEG.',w:ce[0]+ce[1]},{t:'COGNOME',w:ce[2]},{t:'NOME',w:ce[3]},
    {t:'GIORNI GENERI DI\nCONFORTO € 2,41',w:ce[4]},{t:'TOTALE',w:ce[5]}
  ], mm(10));

  let totE = 0;
  (dati.equipaggi||[]).forEach((e,i) => {
    const imp = parseFloat(e.importoGeneri)||0; totE += imp;
    y = rDat(doc, y, [
      {t:String(i+1),w:ce[0],a:'center'},{t:e.grado,w:ce[1]},
      {t:e.cognome,w:ce[2]},{t:e.nome,w:ce[3]},
      {t:String(e.giorniGeneri||0),w:ce[4],a:'center'},
      {t:`\u20ac ${imp.toFixed(2)}`,w:ce[5],a:'right',b:true},
    ], mm(7));
  });
  y += mm(1);
  doc.font(F_BOBL).fontSize(10)
     .text(`\u20ac ${totE.toFixed(2)}`, MAR_L, y, { width: BODY_W, align: 'right' });
  y += mm(18);

  // ── FIRMA ─────────────────────────────────────────────────────────────────
  const fX = MAR_L + BODY_W * 0.45, fW = BODY_W * 0.55;
  doc.font(F_BOLD).fontSize(10)
     .text('IL CAPO NUCLEO', fX, y, { width: fW, align: 'center' });
  y += mm(6);
  doc.text(dati.capoNucleo, fX, y, { width: fW, align: 'center' });
  y += mm(14);
  const bW2=mm(60), bX2=fX+(fW-mm(60))/2;
  border(doc, bX2, y, bW2, mm(13));
  doc.font(F).fontSize(6).fillColor('#555')
     .text('Documento elettronico firmato digitalmente\n(D.Lgs. 07/03/2005 n\u00b082)',
           bX2+mm(2), y+mm(3), { width: bW2-mm(4), align: 'center' });

  doc.end();
  return buf;
}

// ── Helpers tabelle ───────────────────────────────────────────────────────────
function rHdr(doc, y, celle, h) {
  let x = MAR_L;
  celle.forEach(c => {
    border(doc, x, y, c.w, h);
    doc.font(F_BOLD).fontSize(7).fillColor('#000')
       .text(c.t, x+mm(1), y+mm(1.5), { width:c.w-mm(2), height:h-mm(1), align:'center', lineBreak:true });
    x += c.w;
  });
  return y + h;
}
function rDat(doc, y, celle, h) {
  let x = MAR_L;
  celle.forEach(c => {
    border(doc, x, y, c.w, h);
    doc.font(c.b ? F_BOLD : F).fontSize(8).fillColor('#000')
       .text(String(c.t??''), x+mm(1), y+(h-mm(3))/2,
             { width:c.w-mm(2), height:h, align:c.a||'left', lineBreak:false, ellipsis:true });
    x += c.w;
  });
  return y + h;
}

async function genera(nomeTemplate, dati) {
  switch (nomeTemplate) {
    case 'generi-conforto-lettera':  return generaLettera(dati);
    case 'generi-conforto-allegato': return generaAllegato(dati);
    default: throw new Error(`Template sconosciuto: ${nomeTemplate}`);
  }
}
module.exports = { genera };
