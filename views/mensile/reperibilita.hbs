{{! views/mensile/reperibilita.hbs }}
<div class="mensile-container">

  <nav class="mensile-breadcrumb">
    <a href="/mensile"><i class="fas fa-home"></i> MENSILE</a>
    <span class="sep">›</span>
    <span>Reperibilità Mensile</span>
  </nav>

  <div class="mensile-header">
    <div class="mensile-header-icon"><i class="fas fa-phone-alt"></i></div>
    <div>
      <h1>Reperibilità Mensile</h1>
      <p class="mensile-subtitle">Calcola giorni di reperibilità P-42 dagli ordini di volo</p>
    </div>
  </div>

  <form id="formRep" class="mensile-form">

    <div class="mensile-card">
      <div class="mensile-card-title"><i class="fas fa-calendar-alt"></i> Dati Generali</div>
      <div class="mensile-grid-4">
        <div class="campo-gruppo">
          <label>Mese</label>
          <select id="meseIdx" onchange="aggiornaMese()">
            <option value="0">GENNAIO</option><option value="1">FEBBRAIO</option>
            <option value="2">MARZO</option><option value="3">APRILE</option>
            <option value="4">MAGGIO</option><option value="5">GIUGNO</option>
            <option value="6">LUGLIO</option><option value="7">AGOSTO</option>
            <option value="8">SETTEMBRE</option><option value="9">OTTOBRE</option>
            <option value="10">NOVEMBRE</option><option value="11">DICEMBRE</option>
          </select>
        </div>
        <div class="campo-gruppo">
          <label>Anno</label>
          <input type="number" id="anno" value="{{anno}}" min="2020" max="2099">
        </div>
        <div class="campo-gruppo">
          <label>Giorni nel mese</label>
          <div class="info-badge" id="giorniMeseBadge">— gg</div>
        </div>
      </div>
    </div>

    <!-- PERSONALE -->
    <div class="mensile-card">
      <div class="mensile-card-title">
        <i class="fas fa-users"></i> Personale da analizzare
        <button type="button" class="btn-aggiungi" id="btnAggiungi">
          <i class="fas fa-plus"></i> Aggiungi
        </button>
      </div>
      <p style="font-size:13px;color:#666;margin:0 0 12px">
        Seleziona tutto il personale NAAF (Piloti + EFV) da verificare negli ordini di volo.
      </p>
      <div class="table-responsive">
        <table class="mensile-table">
          <thead>
            <tr>
              <th class="col-num">#</th>
              <th class="col-grado">Grado</th>
              <th class="col-cognome">Cognome</th>
              <th class="col-nome">Nome</th>
              <th class="col-gg">Giorni Rep.</th>
              <th class="col-del"></th>
            </tr>
          </thead>
          <tbody id="bodyPersonale"></tbody>
        </table>
      </div>
      <div style="margin-top:14px">
        <button type="button" class="btn-calcola" onclick="calcolaReperibilita()">
          <i class="fas fa-calculator"></i> Calcola da Ordini di Volo
        </button>
      </div>
      <div id="msgCalcolo" style="display:none; margin-top:10px; padding:10px 14px; border-radius:6px; font-size:14px;"></div>
    </div>

    <!-- GENERA -->
    <div class="mensile-card mensile-card-genera">
      <div class="genera-actions">
        <button type="button" class="btn-genera" id="btnGenera">
          <i class="fas fa-file-pdf"></i> Genera Report PDF
        </button>
        <button type="button" class="btn-reset" onclick="resetForm()">
          <i class="fas fa-undo"></i> Reset
        </button>
      </div>
    </div>
  </form>

  <div id="risultatoBox" class="mensile-risultato" style="display:none">
    <div class="risultato-ok"><i class="fas fa-check-circle"></i><strong>Report generato!</strong></div>
    <div id="listaFiles" class="lista-files"></div>
  </div>
  <div id="erroreBox" class="mensile-errore" style="display:none">
    <i class="fas fa-exclamation-triangle"></i><span id="erroreMsg"></span>
  </div>

  <!-- MODALE -->
  <div id="modalePersonale" class="modale" style="display:none">
    <div class="modale-box">
      <div class="modale-titolo">
        <i class="fas fa-users"></i> Seleziona Personale
        <button type="button" class="modale-chiudi" onclick="chiudiModale('modalePersonale')">&#x2715;</button>
      </div>
      <div id="listaPersonale" class="modale-lista"></div>
    </div>
  </div>

</div>
<script>
var CFG = { personale:{}, tariffe:{} };
var giorniMese = 31, idxP = 0;
function $(s){ return document.getElementById(s); }
function esc(s){ return (s||'').replace(/"/g,'&quot;'); }
function apriModale(id){ $(id).style.display='flex'; }
function chiudiModale(id){ $(id).style.display='none'; }
function mkBtn(grado,nome){
  var btn=document.createElement('button'); btn.type='button'; btn.className='modale-item';
  btn.innerHTML='<span class="item-grado">'+grado+'</span><span class="item-nome">'+nome+'</span>';
  return btn;
}
function getVal(tr,field){ var el=tr.querySelector('[data-field="'+field+'"]'); return el?el.value:''; }

document.addEventListener('DOMContentLoaded', async function(){
  var oggi=new Date();
  $('meseIdx').value=oggi.getMonth();
  $('anno').value=oggi.getFullYear();
  await caricaConfig();
  await aggiornaMese();
  $('btnAggiungi').onclick=function(){ apriModale('modalePersonale'); };
  $('btnGenera').onclick=generaPDF;
  document.querySelectorAll('.modale').forEach(function(el){
    el.addEventListener('click',function(e){ if(e.target===el) el.style.display='none'; });
  });
});

async function caricaConfig(){
  try{ CFG=await(await fetch('/mensile/api/config')).json(); }
  catch(e){ CFG={personale:{capoNucleo:[],piloti:[],efv:[]},tariffe:{}}; }

  var lista=$('listaPersonale'); lista.innerHTML='';
  var tutti=[].concat(CFG.personale.piloti||[]).concat(CFG.personale.efv||[]);
  tutti.forEach(function(p){
    var btn=mkBtn(p.grado,p.cognome+' '+p.nome);
    btn.onclick=function(){ aggiungiPersonale(p); chiudiModale('modalePersonale'); };
    lista.appendChild(btn);
  });
}

async function aggiornaMese(){
  var mi=$('meseIdx').value, an=$('anno').value;
  try{ var j=await(await fetch('/mensile/api/giorni?mese='+mi+'&anno='+an)).json(); giorniMese=j.giorni; }
  catch(e){ giorniMese=[31,28,31,30,31,30,31,31,30,31,30,31][parseInt(mi)]; }
  $('giorniMeseBadge').textContent=giorniMese+' gg';
}

function aggiungiPersonale(p){
  var idx=idxP++, tbody=$('bodyPersonale');
  var n=p||{};
  var tr=document.createElement('tr'); tr.dataset.idx=idx;
  tr.innerHTML=
    '<td class="num-cell">'+(tbody.children.length+1)+'</td>'
    +'<td><input type="text" class="inp-testo inp-grado" data-field="grado" value="'+esc(n.grado)+'"></td>'
    +'<td><input type="text" class="inp-testo inp-upper" data-field="cognome" value="'+esc(n.cognome)+'"></td>'
    +'<td><input type="text" class="inp-testo" data-field="nome" value="'+esc(n.nome)+'"></td>'
    +'<td><input type="number" class="inp-num" data-field="giorni" min="0" max="'+giorniMese+'" value="0" style="width:70px"></td>'
    +'<td><button type="button" class="btn-rimuovi" onclick="rimuoviRiga(this)"><i class="fas fa-trash"></i></button></td>';
  tbody.appendChild(tr);
}

function rimuoviRiga(btn){
  var tbody=btn.closest('tr').parentNode;
  btn.closest('tr').remove();
  tbody.querySelectorAll('tr').forEach(function(r,i){ r.querySelector('.num-cell').textContent=i+1; });
}

async function calcolaReperibilita(){
  var cognomi=[];
  document.querySelectorAll('#bodyPersonale tr').forEach(function(tr){
    var cog=getVal(tr,'cognome');
    if(cog&&cog.trim()) cognomi.push(cog.trim());
  });
  if(!cognomi.length){ mostraMsg('Aggiungi prima il personale.', false); return; }

  var btn=$('btnCalcola')||document.querySelector('.btn-calcola');
  btn.disabled=true;
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Calcolo in corso...';

  try{
    var j=await(await fetch('/mensile/api/calcola-reperibilita',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ anno:$('anno').value, meseIdx:$('meseIdx').value, cognomi:cognomi })
    })).json();

    if(j.ok){
      document.querySelectorAll('#bodyPersonale tr').forEach(function(tr){
        var cog=getVal(tr,'cognome').trim().toUpperCase();
        if(j.spettanze[cog]!==undefined){
          tr.querySelector('[data-field="giorni"]').value=j.spettanze[cog];
        }
      });
      var msg='Reperibilità calcolata! Giorni analizzati: '+j.giorniAnalizzati;
      if(j.giorniSenzaFirmato>0) msg+=' ('+j.giorniSenzaFirmato+' senza file firmato)';
      mostraMsg(msg, true);
    } else { mostraMsg('Errore: '+j.errore, false); }
  } catch(e){ mostraMsg('Errore: '+e.message, false); }
  finally{
    btn.disabled=false;
    btn.innerHTML='<i class="fas fa-calculator"></i> Calcola da Ordini di Volo';
  }
}

async function generaPDF(){
  var personale=[];
  document.querySelectorAll('#bodyPersonale tr').forEach(function(tr){
    var cog=getVal(tr,'cognome');
    if(!cog||!cog.trim()) return;
    personale.push({
      grado:   getVal(tr,'grado'),
      cognome: cog.trim(),
      nome:    getVal(tr,'nome'),
      giorni:  parseInt(getVal(tr,'giorni'))||0
    });
  });
  if(!personale.length){ mostraErr('Inserire almeno un membro del personale.'); return; }

  var btn=$('btnGenera'); btn.disabled=true;
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Generazione...';
  $('risultatoBox').style.display=$('erroreBox').style.display='none';
  try{
    var j=await(await fetch('/mensile/reperibilita/genera',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ meseIdx:$('meseIdx').value, anno:$('anno').value, personale:personale })
    })).json();
    if(j.ok){
      $('listaFiles').innerHTML=j.files.map(function(f){
        return '<div class="file-item">'
          +'<i class="fas fa-file-pdf"></i>'
          +'<span class="file-nome">'+f.nome+'</span>'
          +'<div class="file-btns">'
          +'<a href="/mensile/view?path='+encodeURIComponent(f.path)+'" class="btn-view" target="_blank"><i class="fas fa-eye"></i> Visualizza</a>'
          +'<a href="/mensile/download?path='+encodeURIComponent(f.path)+'" class="btn-download" download><i class="fas fa-download"></i> Scarica</a>'
          +'</div></div>';
      }).join('');
      $('risultatoBox').style.display='block';
      $('risultatoBox').scrollIntoView({behavior:'smooth'});
    } else { mostraErr(j.errore||'Errore sconosciuto.'); }
  } catch(e){ mostraErr('Errore: '+e.message); }
  finally{ btn.disabled=false; btn.innerHTML='<i class="fas fa-file-pdf"></i> Genera Report PDF'; }
}

function mostraMsg(testo, ok){
  var div=$('msgCalcolo');
  div.textContent=testo; div.style.display='block';
  div.style.background=ok?'#d4edda':'#f8d7da';
  div.style.color=ok?'#155724':'#721c24';
  div.style.border=ok?'1px solid #c3e6cb':'1px solid #f5c6cb';
  setTimeout(function(){ div.style.display='none'; }, 6000);
}
function mostraErr(msg){
  $('erroreMsg').textContent=msg; $('erroreBox').style.display='block';
  $('erroreBox').scrollIntoView({behavior:'smooth'});
}
function resetForm(){
  if(!confirm('Azzerare tutti i dati?')) return;
  $('bodyPersonale').innerHTML=''; idxP=0;
  $('risultatoBox').style.display=$('erroreBox').style.display='none';
}
</script>
